<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/auth_nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.refactoringlife.auth.features.login.presentation.fragment.LoginFragment"
        android:label="Login">
        <deepLink app:uri="socialpets://com.refactoringlife.socialpets/auth/login" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.refactoringlife.auth.features.register.presentation.fragment.RegisterFragment"
        android:label="Register">
        <deepLink app:uri="socialpets://com.refactoringlife.socialpets/auth/register" />
    </fragment>

</navigation>